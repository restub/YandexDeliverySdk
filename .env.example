# Конфигурация для доступа к API Яндекс Доставки
# Скопируйте этот файл в .env и заполните реальными значениями
YANDEX_DELIVERY_API_TOKEN=your_api_token_here
YANDEX_DELIVERY_API_URL=https://api.delivery.yandex.ru
# Дополнительные переменные, если нужны
# YANDEX_DELIVERY_CLIENT_ID=your_client_id
# YANDEX_DELIVERY_CLIENT_SECRET=your_client_secret